<?xml version="1.0" encoding="utf-8"?>
<!--
    Spanish (es) string resources for MedicalSymptomPreScreener.

    These strings are used by Android's resource system when the device locale is Spanish.
    For the in-app language toggle (EN/ES switch in SettingsScreen), the Gemini AI output
    is translated at runtime via ML Kit (TranslationRepository), and static UI labels
    are conditionally selected in Kotlin using the `isSpanishEnabled` StateFlow from
    SharedTriageViewModel / SettingsViewModel.

    IMPORTANT: All emergency-related strings must remain accurate and unambiguous.
    The number 911 is preserved in all emergency strings — it is the universal emergency
    number for US users regardless of language.
-->
<resources>
    <!-- App name -->
    <string name="app_name">PreEvaluador de Síntomas Médicos</string>

    <!-- ── Input Screen ─────────────────────────────────────────────────── -->
    <string name="input_screen_title">PreEvaluador Médico con IA</string>
